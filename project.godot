; Ricochet Requiem — P0 gray-box prototype
config_version=5

[application]

config/name="Ricochet Requiem"
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"

[autoload]

Balance="*res://scripts/balance.gd"
SaveData="*res://scripts/save_data.gd"
Game="*res://scripts/meta.gd"
FX="*res://scripts/fx.gd"

[input]

move_up={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":87)]}
move_down={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":83)]}
move_left={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":65)]}
move_right={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":68)]}
dash={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":32)]}
fire={"deadzone": 0.2, "events": [Object(InputEventMouseButton,"button_index":1)]}
cadenza={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":81)]}
advance_room={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":69)]}
restart_run={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":82)]}
choose_card_1={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":49)]}
choose_card_2={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":50)]}
choose_card_3={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":51)]}
choose_encore_1={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":49)]}
choose_encore_2={"deadzone": 0.2, "events": [Object(InputEventKey,"physical_keycode":50)]}

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false
